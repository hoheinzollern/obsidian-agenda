<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_row"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <ImageView
        android:id="@+id/widget_row_checkbox"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:padding="4dp"
        android:src="@drawable/widget_check_blank"
        android:contentDescription="Toggle status" />

    <LinearLayout
        android:id="@+id/widget_row_body"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="4dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_row_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/widget_title"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_row_tags"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/widget_secondary"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:visibility="gone" />
    </LinearLayout>

    <ImageView
        android:id="@+id/widget_row_more"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:padding="4dp"
        android:src="@drawable/widget_more"
        android:contentDescription="More options" />

</LinearLayout>
